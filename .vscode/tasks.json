{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Firmware",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "10_build"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Flash MCU",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "10_build",
                "--target",
                "flash"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Clean Build",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Remove-Item -Recurse -Force 10_build"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
    "label": "Erase Chip",
    "type": "shell",
    "command": "openocd",
    "args": [
        "-f", "interface/stlink.cfg",
        "-f", "target/stm32f1x.cfg",
        "-c", "init; halt; stm32f1x mass_erase 0; exit"
    ],
    "group": "build",
    "problemMatcher": []
}
    ]
}